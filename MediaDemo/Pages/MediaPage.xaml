<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="MediaDemo.Pages.MediaPage"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBackgroundLight}, Dark={StaticResource PageBackgroundDark}}"
             Title="Media Demo">

    <Grid RowDefinitions="*,Auto,Auto,Auto,Auto" Padding="16" RowSpacing="12">

        <!-- Video surface -->
        <Border Grid.Row="0"
                BackgroundColor="Black"
                StrokeThickness="0">
            <toolkit:MediaElement x:Name="Player"
                                  Aspect="AspectFit"
                                  ShouldAutoPlay="False"
                                  ShouldShowPlaybackControls="False"
                                  Source="https://download.blender.org/durian/trailer/sintel_trailer-720p.mp4"
                                  Volume="0.8" />
        </Border>

        <!-- Position slider + time labels -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
            <Label Grid.Column="0"
                   x:Name="PositionLabel"
                   Text="0:00"
                   VerticalOptions="Center"
                   FontSize="13"
                   TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />

            <Slider Grid.Column="1"
                    x:Name="PositionSlider"
                    Minimum="0"
                    Maximum="1"
                    Value="0"
                    DragStarted="OnPositionDragStarted"
                    DragCompleted="OnPositionDragCompleted"
                    MinimumTrackColor="{StaticResource AccentColor}"
                    ThumbColor="{StaticResource AccentColor}" />

            <Label Grid.Column="2"
                   x:Name="DurationLabel"
                   Text="0:00"
                   VerticalOptions="Center"
                   FontSize="13"
                   TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
        </Grid>

        <!-- Transport controls -->
        <HorizontalStackLayout Grid.Row="2" Spacing="8" HorizontalOptions="Center">
            <Button Text="Play"  Style="{StaticResource ControlButton}" Clicked="OnPlayClicked" />
            <Button Text="Pause" Style="{StaticResource ControlButton}" Clicked="OnPauseClicked" />
            <Button Text="Stop"  Style="{StaticResource ControlButton}" Clicked="OnStopClicked" />
            <Button x:Name="MuteButton" Text="Mute" Style="{StaticResource ControlButton}" Clicked="OnMuteClicked" />
        </HorizontalStackLayout>

        <!-- Volume slider -->
        <Grid Grid.Row="3" ColumnDefinitions="Auto,*" ColumnSpacing="8">
            <Label Grid.Column="0"
                   Text="Volume:"
                   VerticalOptions="Center"
                   FontSize="13"
                   TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />

            <Slider Grid.Column="1"
                    x:Name="VolumeSlider"
                    Minimum="0"
                    Maximum="1"
                    Value="0.8"
                    ValueChanged="OnVolumeChanged"
                    MinimumTrackColor="{StaticResource AccentColor}"
                    ThumbColor="{StaticResource AccentColor}" />
        </Grid>

        <!-- URL / file-path entry — explicit row so the entry is easy to find -->
        <Grid Grid.Row="4" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
            <Label Grid.Column="0"
                   Text="Source URL or file:"
                   VerticalOptions="Center"
                   FontSize="13"
                   TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />

            <Entry Grid.Column="1"
                   x:Name="UrlEntry"
                   Placeholder="paste an http/https URL or a local path like /home/me/video.mp4"
                   ClearButtonVisibility="WhileEditing"
                   TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                   PlaceholderColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}"
                   Completed="OnLoadClicked" />

            <Button Grid.Column="2"
                    Text="Load"
                    Style="{StaticResource ControlButton}"
                    Clicked="OnLoadClicked" />
        </Grid>

    </Grid>
</ContentPage>
